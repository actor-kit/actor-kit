{
  "name": "actor-kit",
  "version": "0.51.0",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./storybook": {
      "types": "./src/storybook.ts",
      "import": "./src/storybook.ts"
    },
    "./test": {
      "types": "./src/test.ts",
      "import": "./src/test.ts"
    },
    "./worker": {
      "types": "./src/worker.ts",
      "import": "./src/worker.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "rollup -c --bundleConfigAsCjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests e2e playwright.config.ts examples/remix-actorkit-todo examples/tanstack-start-actorkit-todo && npm --prefix examples/nextjs-actorkit-todo run lint",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run test:e2e:nextjs && npm run test:e2e:remix && npm run test:e2e:tanstack-start",
    "test:e2e:nextjs": "playwright test --config playwright.next.config.ts",
    "test:e2e:remix": "playwright test --config playwright.remix.config.ts",
    "test:e2e:tanstack-start": "playwright test --config playwright.tanstack.config.ts",
    "check": "npm run build && npm run typecheck && npm run lint && npm run test:coverage",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "xstate",
    "partykit",
    "actor",
    "state-machine"
  ],
  "author": "jonmumm",
  "license": "ISC",
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "xstate": "^5.18.0",
    "zod": "^3.23.0"
  },
  "dependencies": {
    "cloudflare": "^3.5.0",
    "fast-json-patch": "^3.1.1",
    "immer": "^10.2.0",
    "jose": "^5.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@storybook/react": "^8.6.18",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.2",
    "@types/use-sync-external-store": "^0.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsondiffpatch": "^0.7.3",
    "react": "^19.2.0",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.4.0",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0",
    "xstate": "^5.28.0",
    "xstate-migrate": "^0.0.5",
    "zod": "^3.25.76"
  },
  "type": "module"
}
