{
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm --filter @actor-kit/types build && pnpm --filter '@actor-kit/*' --filter '!@actor-kit/types' build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter '@actor-kit/*' test",
    "test:unit": "pnpm --filter '@actor-kit/*' test",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "sharp",
      "unrs-resolver",
      "workerd"
    ],
    "patchedDependencies": {
      "fast-json-patch": "patches/fast-json-patch.patch"
    }
  }
}
