{
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm --filter actor-kit build",
    "typecheck": "pnpm --filter actor-kit typecheck",
    "lint": "pnpm --filter actor-kit lint",
    "test": "pnpm --filter actor-kit test",
    "test:unit": "pnpm --filter actor-kit test:unit",
    "test:integration": "pnpm --filter actor-kit test:integration",
    "test:workers": "pnpm --filter actor-kit test:workers",
    "test:build-fixtures": "pnpm --filter actor-kit test:build-fixtures",
    "test:coverage": "pnpm --filter actor-kit test:coverage",
    "test:mutate": "pnpm --filter actor-kit test:mutate",
    "test:mutate:incremental": "pnpm --filter actor-kit test:mutate:incremental",
    "test:mutate:full": "pnpm --filter actor-kit test:mutate:full",
    "test:e2e": "pnpm --filter actor-kit test:e2e",
    "test:e2e:nextjs": "pnpm --filter actor-kit test:e2e:nextjs",
    "test:e2e:tanstack-start": "pnpm --filter actor-kit test:e2e:tanstack-start",
    "analyze:crap": "pnpm --filter actor-kit analyze:crap",
    "check": "pnpm --filter actor-kit check",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3"
  },
  "lint-staged": {
    "packages/actor-kit/**/*.{js,mjs,cjs,ts,tsx}": "eslint --fix --config packages/actor-kit/eslint.config.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "sharp",
      "unrs-resolver",
      "workerd"
    ],
    "patchedDependencies": {
      "fast-json-patch": "packages/actor-kit/patches/fast-json-patch.patch"
    }
  }
}
