{
  "name": "remix-actorkit-todo",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "deploy": "remix build && wrangler deploy",
    "dev": "NODE_PATH=./node_modules NODE_OPTIONS=--preserve-symlinks remix dev -c \"wrangler dev\"",
    "dev:e2e": "NODE_PATH=./node_modules NODE_OPTIONS=--preserve-symlinks ACTOR_KIT_HOST=127.0.0.1:8789 ACTOR_KIT_SECRET=actor-kit-dev-secret remix dev --manual --port 3003 -c \"wrangler dev --port 8789\"",
    "test:e2e": "playwright test",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@remix-run/dev": "^2.12.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.5.2",
    "wrangler": "^3.60.3"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.12.1",
    "@remix-run/cloudflare-workers": "^2.16.8",
    "@remix-run/css-bundle": "^2.12.1",
    "@remix-run/react": "^2.12.1",
    "@remix-run/server-runtime": "^2.12.1",
    "actor-kit": "workspace:*",
    "isbot": "^4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xstate": "^5.18.1",
    "zod": "^3.23.8"
  }
}
