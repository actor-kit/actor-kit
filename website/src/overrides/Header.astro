---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="header sl-flex">
  <div class="left-group sl-flex">
    <SiteTitle />
    <nav class="header-nav sl-flex">
      <a href="/getting-started/overview/" class="header-nav-link">Docs</a>
      <a href="https://github.com/actor-kit/actor-kit/releases" class="header-nav-link">Changelog</a>
    </nav>
  </div>
  <div class="right-group sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<style is:global>
  .header.sl-flex {
    justify-content: space-between;
    align-items: center;
    height: 100%;
    flex-wrap: nowrap;
  }

  .left-group.sl-flex {
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 1;
    min-width: 0;
    flex-wrap: nowrap;
  }

  .header-nav.sl-flex {
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
    margin-left: 0.25rem;
  }

  .header-nav-link {
    padding: 0.35rem 0.6rem;
    border-radius: 0.375rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .header-nav-link:hover {
    color: var(--sl-color-white);
  }

  .right-group.sl-flex {
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
  }

  /* Hide nav links on mobile — sidebar handles navigation */
  @media (max-width: 50rem) {
    .header-nav {
      display: none !important;
    }
  }
</style>
