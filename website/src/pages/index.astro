---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

const tabs = [
  {
    id: "machine",
    label: "Machine",
    file: "todo.machine.ts",
    code: `<span class="ck">import</span> { setup, assign } <span class="ck">from</span> <span class="cs">"xstate"</span>;
<span class="ck">import</span> { produce } <span class="ck">from</span> <span class="cs">"immer"</span>;

<span class="ck">export const</span> todoMachine = <span class="cf">setup</span>({
  <span class="cp">types</span>: {
    <span class="cp">context</span>: {} <span class="ck">as</span> {
      <span class="cp">public</span>: { todos: Todo[]; lastSync: <span class="ct">number</span> };
      <span class="cp">private</span>: Record&lt;<span class="ct">string</span>, { filter: Filter }&gt;;
    },
    <span class="cp">events</span>: {} <span class="ck">as</span> TodoEvent,
  },
  <span class="cp">actions</span>: {
    <span class="cf">addTodo</span>: <span class="cf">assign</span>(({ context, event }) =&gt;
      <span class="cf">produce</span>(context, (draft) =&gt; {
        draft.public.todos.<span class="cf">push</span>({
          id: crypto.<span class="cf">randomUUID</span>(),
          text: event.text,
          completed: <span class="cb">false</span>,
        });
      })
    ),
  },
}).<span class="cf">createMachine</span>({
  <span class="cp">id</span>: <span class="cs">"todo"</span>,
  <span class="cp">initial</span>: <span class="cs">"ready"</span>,
  <span class="cp">states</span>: { <span class="cp">ready</span>: {
    <span class="cp">on</span>: {
      <span class="cp">ADD_TODO</span>:    { actions: <span class="cs">"addTodo"</span> },
      <span class="cp">DELETE_TODO</span>: { guard: <span class="cs">"isOwner"</span>, actions: <span class="cs">"deleteTodo"</span> },
    },
  }},
});`,
  },
  {
    id: "server",
    label: "Server",
    file: "todo.server.ts",
    code: `<span class="ck">import</span> { <span class="cf">createMachineServer</span> } <span class="ck">from</span> <span class="cs">"@actor-kit/worker"</span>;
<span class="ck">import</span> { todoMachine } <span class="ck">from</span> <span class="cs">"./todo.machine"</span>;
<span class="ck">import</span> {
  TodoClientEventSchema,
  TodoServiceEventSchema,
  TodoInputPropsSchema,
} <span class="ck">from</span> <span class="cs">"./todo.schemas"</span>;

<span class="cm">// This becomes a Cloudflare Durable Object</span>
<span class="ck">export const</span> Todo = <span class="cf">createMachineServer</span>({
  <span class="cp">machine</span>: todoMachine,
  <span class="cp">schemas</span>: {
    <span class="cp">clientEvent</span>: TodoClientEventSchema,
    <span class="cp">serviceEvent</span>: TodoServiceEventSchema,
    <span class="cp">inputProps</span>: TodoInputPropsSchema,
  },
  <span class="cp">options</span>: { <span class="cp">persisted</span>: <span class="cb">true</span> },
});`,
  },
  {
    id: "worker",
    label: "Worker",
    file: "server.ts",
    code: `<span class="ck">import</span> { <span class="cf">createActorKitRouter</span> } <span class="ck">from</span> <span class="cs">"@actor-kit/worker"</span>;
<span class="ck">import</span> { WorkerEntrypoint } <span class="ck">from</span> <span class="cs">"cloudflare:workers"</span>;
<span class="ck">import</span> { Todo } <span class="ck">from</span> <span class="cs">"./todo.server"</span>;

<span class="cm">// Routes: /api/todo/{actorId}</span>
<span class="ck">const</span> router = <span class="cf">createActorKitRouter</span>([<span class="cs">"todo"</span>]);

<span class="ck">export</span> { Todo };

<span class="ck">export default class</span> <span class="ct">Worker</span> <span class="ck">extends</span> <span class="ct">WorkerEntrypoint</span> {
  <span class="cf">fetch</span>(request: Request) {
    <span class="ck">if</span> (request.url.<span class="cf">includes</span>(<span class="cs">"/api/"</span>)) {
      <span class="ck">return</span> <span class="cf">router</span>(request, <span class="ck">this</span>.env, <span class="ck">this</span>.ctx);
    }
    <span class="ck">return new</span> <span class="ct">Response</span>(<span class="cs">"Powered by ActorKit"</span>);
  }
}`,
  },
  {
    id: "client",
    label: "React",
    file: "todo.context.tsx + components/TodoItem.tsx",
    code: `<span class="cm">// todo.context.tsx</span>
<span class="ck">import</span> { <span class="cf">createActorKitContext</span> } <span class="ck">from</span> <span class="cs">"@actor-kit/react"</span>;
<span class="ck">import type</span> { TodoMachine } <span class="ck">from</span> <span class="cs">"./todo.machine"</span>;

<span class="ck">export const</span> TodoContext = <span class="cf">createActorKitContext</span>&lt;<span class="ct">TodoMachine</span>&gt;(<span class="cs">"todo"</span>);

<span class="cm">// components/TodoItem.tsx — subscribes to one todo only</span>
<span class="ck">import</span> { TodoContext } <span class="ck">from</span> <span class="cs">"../todo.context"</span>;

<span class="ck">export function</span> <span class="cf">TodoItem</span>({ <span class="cp">id</span> }: { id: <span class="ct">string</span> }) {
  <span class="cm">// Granular selector — re-renders only when THIS todo changes</span>
  <span class="ck">const</span> todo = TodoContext.<span class="cf">useSelector</span>(
    (s) =&gt; s.public.todos.<span class="cf">find</span>((t) =&gt; t.id === id)!
  );
  <span class="ck">const</span> send = TodoContext.<span class="cf">useSend</span>();

  <span class="ck">return</span> (
    &lt;<span class="ct">li</span>&gt;
      {todo.text}
      &lt;<span class="ct">button</span> <span class="cp">onClick</span>={() =&gt;
        <span class="cf">send</span>({ <span class="cp">type</span>: <span class="cs">"TOGGLE_TODO"</span>, <span class="cp">id</span> })
      }&gt;
        {todo.completed ? <span class="cs">"Undo"</span> : <span class="cs">"Done"</span>}
      &lt;/<span class="ct">button</span>&gt;
    &lt;/<span class="ct">li</span>&gt;
  );
}`,
  },
];
---

<StarlightPage
  frontmatter={{
    title: "Actor Kit",
    description:
      "Type-safe state machines on Cloudflare Durable Objects with real-time client sync.",
    template: "splash",
    pagefind: false,
  }}
>
  <div class="landing">
    <!-- Hero -->
    <section class="landing-hero">
      <h1 class="landing-hero-title">
        <span class="landing-hero-gradient">Event-Driven State</span> on the Edge.<br/>
        <span class="landing-hero-muted">Synced in Real Time.</span>
      </h1>
      <p class="landing-hero-sub">
        Actor Kit runs event-driven state inside Cloudflare Durable Objects with
        automatic real-time sync. Bring your own state library &mdash; plain reducers,
        XState, @xstate/store, or Redux.
      </p>
      <div class="landing-hero-actions">
        <a href="/getting-started/overview/" class="btn btn-primary">
          Get Started
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a href="https://github.com/actor-kit/actor-kit" class="btn btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="features-grid">
        <div class="feature">
          <div class="feature-icon icon-cf">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
          </div>
          <h3>Durable Object Runtime</h3>
          <p>Each actor is a Cloudflare Durable Object &mdash; single-threaded, globally addressable, with built-in storage.</p>
        </div>
        <div class="feature">
          <div class="feature-icon icon-sync">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3>Real-time Sync</h3>
          <p>WebSocket + JSON Patch diffs + checksum deduplication. Clients stay current with minimal bytes.</p>
        </div>
        <div class="feature">
          <div class="feature-icon icon-type">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>End-to-End Type Safety</h3>
          <p>Generics at compile time. Zod at runtime boundaries. Zero <code>any</code>, zero <code>as</code> casting.</p>
        </div>
        <div class="feature">
          <div class="feature-icon icon-ctx">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 12h18"/></svg>
          </div>
          <h3>Caller-Scoped Views</h3>
          <p>Each caller sees a different projection of state. Game players see their hand; spectators see the board.</p>
        </div>
        <div class="feature">
          <div class="feature-icon icon-xs">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="m8 12 3 3 5-5"/></svg>
          </div>
          <h3>Pluggable State Management</h3>
          <p>Plain reducers, XState, @xstate/store, or Redux. Any library that does state + event &rarr; state.</p>
        </div>
        <div class="feature">
          <div class="feature-icon icon-fw">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
          </div>
          <h3>Framework Integrations</h3>
          <p>React hooks. Next.js &amp; TanStack Start SSR. Framework-agnostic core for anything else.</p>
        </div>
      </div>
    </section>

    <!-- Tabbed Code Examples -->
    <section class="code-section">
      <div class="code-section-header">
        <h2>From logic to UI in four files</h2>
        <p>Define your state transitions, wrap as a Durable Object, add routes, and connect React.</p>
      </div>
      <div class="code-tabs">
        <div class="tab-bar">
          {tabs.map((tab, i) => (
            <button
              class:list={["tab-btn", { active: i === 0 }]}
              data-tab={tab.id}
            >
              {tab.label}
            </button>
          ))}
        </div>
        {tabs.map((tab, i) => (
          <div
            class:list={["tab-panel", { active: i === 0 }]}
            data-panel={tab.id}
          >
            <div class="code-block">
              <div class="code-header">
                <span class="code-dot red"></span>
                <span class="code-dot yellow"></span>
                <span class="code-dot green"></span>
                <span class="code-filename">{tab.file}</span>
              </div>
              <pre><code set:html={tab.code} /></pre>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Built for Cloudflare -->
    <section class="cf-section">
      <div class="cf-layout">
        <div class="cf-text">
          <p class="cf-eyebrow">Perfect for Cloudflare Workers</p>
          <h2>Built from the ground up for the edge</h2>
          <div class="cf-features">
            <div class="cf-feat">
              <strong>Globally Distributed</strong>
              <span>Actors run in Cloudflare's 300+ locations worldwide.</span>
            </div>
            <div class="cf-feat">
              <strong>Low Latency</strong>
              <span>Durable Objects maintain state close to users.</span>
            </div>
            <div class="cf-feat">
              <strong>Native Worker Integration</strong>
              <span>Seamless with Workers' existing tooling and ecosystem.</span>
            </div>
            <div class="cf-feat">
              <strong>Framework Support</strong>
              <span>SSR with Next.js, TanStack Start, Remix, and more.</span>
            </div>
          </div>
          <a href="https://developers.cloudflare.com/durable-objects/" class="btn btn-cf">
            Cloudflare Durable Objects
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
        <div class="cf-diagram">
          <div class="diagram-card">
            <div class="diagram-title">Data Flow</div>
            <div class="diagram-flow">
              <div class="flow-step">
                <div class="flow-num">1</div>
                <div class="flow-content">
                  <span class="flow-label">SSR Loader</span>
                  <span class="flow-detail">Creates JWT, fetches initial snapshot via HTTP</span>
                </div>
              </div>
              <div class="flow-arrow">&darr;</div>
              <div class="flow-step">
                <div class="flow-num">2</div>
                <div class="flow-content">
                  <span class="flow-label">React Provider</span>
                  <span class="flow-detail">Renders with snapshot, upgrades to WebSocket</span>
                </div>
              </div>
              <div class="flow-arrow">&darr;</div>
              <div class="flow-step">
                <div class="flow-num">3</div>
                <div class="flow-content">
                  <span class="flow-label">Durable Object</span>
                  <span class="flow-detail">Actor logic processes events, persists state</span>
                </div>
              </div>
              <div class="flow-arrow">&darr;</div>
              <div class="flow-step">
                <div class="flow-num">4</div>
                <div class="flow-content">
                  <span class="flow-label">JSON Patch Sync</span>
                  <span class="flow-detail">Caller-scoped diffs broadcast to all clients</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Use Cases -->
    <section class="use-cases">
      <h2>What you can build</h2>
      <div class="uc-grid">
        <div class="uc">
          <div class="uc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
          </div>
          <strong>AI Agents</strong>
          <span>Orchestrate and persist state for autonomous agents in real time.</span>
        </div>
        <div class="uc">
          <div class="uc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          </div>
          <strong>Multiplayer Games</strong>
          <span>Shared game state with per-player private data and low-latency sync.</span>
        </div>
        <div class="uc">
          <div class="uc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 6.1H3"/><path d="M21 12.1H3"/><path d="M15.1 18H3"/></svg>
          </div>
          <strong>Collaborative Tools</strong>
          <span>Real-time editing, whiteboards, shared documents with conflict resolution.</span>
        </div>
        <div class="uc">
          <div class="uc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"/></svg>
          </div>
          <strong>IoT &amp; Edge Apps</strong>
          <span>Device state management at the edge, close to your users worldwide.</span>
        </div>
      </div>
    </section>

    <!-- Packages -->
    <section class="packages">
      <h2>Focused packages</h2>
      <p class="packages-sub">Import only what you need.</p>
      <div class="pkg-grid">
        <a href="/api/core/" class="pkg">
          <strong>@actor-kit/core</strong>
          <span>defineLogic, createDurableActor, auth</span>
        </a>
        <a href="/api/browser/" class="pkg">
          <strong>@actor-kit/browser</strong>
          <span>WebSocket client &amp; JSON Patch sync</span>
        </a>
        <a href="/api/react/" class="pkg">
          <strong>@actor-kit/react</strong>
          <span>useSelector, useSend hooks</span>
        </a>
        <a href="/api/server/" class="pkg">
          <strong>@actor-kit/server</strong>
          <span>Server-side data fetching</span>
        </a>
        <a href="/api/core/" class="pkg">
          <strong>@actor-kit/xstate</strong>
          <span>XState v5 adapter</span>
        </a>
        <a href="/api/core/" class="pkg">
          <strong>@actor-kit/xstate-store</strong>
          <span>@xstate/store adapter</span>
        </a>
        <a href="/api/core/" class="pkg">
          <strong>@actor-kit/redux</strong>
          <span>Redux reducer adapter</span>
        </a>
        <a href="/api/test/" class="pkg">
          <strong>@actor-kit/test</strong>
          <span>Mock client &amp; transition testing</span>
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <h2>Start building</h2>
      <p>Build a real-time todo app in 8 steps.</p>
      <div class="landing-hero-actions">
        <a href="/getting-started/quick-start/" class="btn btn-primary">
          Quick Start Guide
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a href="/getting-started/overview/" class="btn btn-secondary">Read the Docs</a>
      </div>
    </section>
  </div>

  <style>
    /* Hide Starlight's default page title on landing */
    :global(.page-title-row) { display: none !important; }
    :global([data-has-hero] .content-panel:first-child) { display: none !important; }

    .landing { max-width: 68rem; margin: 0 auto; padding: 0 1.5rem; }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(1.5rem); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }

    /* ── Hero ── */
    .landing-hero {
      text-align: center;
      padding: 4rem 0 3.5rem;
      max-width: 50rem;
      margin: 0 auto;
      animation: fadeUp 0.6s ease-out both;
    }

    .landing-hero-title {
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      line-height: 1.12;
      letter-spacing: -0.035em;
      font-weight: 800;
      margin: 0 0 1.5rem;
      color: var(--sl-color-white);
    }

    .landing-hero-gradient {
      background: linear-gradient(
        135deg,
        #f6821f 0%, #faad3f 40%, #f6821f 70%, #faad3f 100%
      );
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 6s linear infinite;
    }

    .landing-hero-muted {
      color: var(--sl-color-gray-3);
    }

    .landing-hero-sub {
      font-size: 1.15rem;
      line-height: 1.6;
      color: var(--sl-color-gray-2);
      margin: 0 auto 2.5rem;
      max-width: 36rem;
      animation: fadeUp 0.6s 0.15s ease-out both;
    }

    .landing-hero-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      animation: fadeUp 0.6s 0.25s ease-out both;
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.7rem 1.5rem; border-radius: 0.5rem;
      font-size: 0.9rem; font-weight: 600;
      text-decoration: none; transition: all 0.15s ease;
    }

    .btn-primary {
      background: linear-gradient(135deg, #f6821f, #e8720a);
      color: #fff;
      box-shadow: 0 2px 8px rgba(246, 130, 31, 0.3);
    }
    .btn-primary:hover { box-shadow: 0 4px 16px rgba(246, 130, 31, 0.45); transform: translateY(-1px); }

    .btn-secondary {
      border: 1px solid var(--sl-color-gray-5);
      color: var(--sl-color-text); background: transparent;
    }
    .btn-secondary:hover { border-color: var(--sl-color-gray-3); }

    .btn-ghost {
      color: var(--sl-color-gray-2);
      background: transparent;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 2rem;
      padding: 0.55rem 1.25rem;
    }
    .btn-ghost:hover { border-color: var(--sl-color-gray-3); color: var(--sl-color-white); }

    .btn-cf {
      background: rgba(246, 130, 31, 0.1);
      color: #f6821f;
